    "def search_report(query: str, top_k: int = 3):\n",
    "    \"\"\"사업보고서에서 특정 주제 검색\"\"\"\n",
    "    results = retrieve(query, report_index, report_chunks, df_report, top_k)\n",
    "    print(f\"\\n🔎 사업보고서 검색: '{query}'\")\n",
    "    print(\"=\" * 60)\n",
    "    for i, r in enumerate(results, 1):\n",
    "        print(f\"[{i}] p.{r['meta']['start_page']}~{r['meta']['end_page']} \"\n",
    "              f\"(유사도: {r['score']:.3f})\")\n",
    "        print(r['meta']['preview'][:300])\n",
    "        print()\n",
    "\n",
    "\n",
    "# 예시 검색\n",
    "search_report(\"원자재 가격 상승 리스크 대응\")\n",
    "search_report(\"전기차 배터리 공급망\")"

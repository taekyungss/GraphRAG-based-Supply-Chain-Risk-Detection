   "source": [
    "# ── 현대자동차 사업보고서 PDF 로드 및 청킹 ──────────────────────────────\n",
    "# 전략: 3페이지씩 묶어서 하나의 청크로 구성\n",
    "# 100자 미만의 빈 페이지는 건너뜀\n",
    "\n",
    "def load_pdf_chunks(pdf_path: str, chunk_pages: int = 3, min_chars: int = 100):\n",
    "    \"\"\"\n",
    "    PDF를 chunk_pages 페이지 단위로 묶어 청크 리스트와 메타데이터 반환\n",
    "    Returns:\n",
    "        chunks: List[str]  – 각 청크의 텍스트\n",
    "        meta:   List[dict] – {'start_page': int, 'end_page': int, 'text': str}\n",
    "    \"\"\"\n",
    "    reader = PdfReader(pdf_path)\n",
    "    total_pages = len(reader.pages)\n",
    "    print(f\"  📄 총 {total_pages}페이지 로드 중...\")\n",
    "\n",
    "    # 페이지별 텍스트 추출 (빈 페이지 필터링)\n",
    "    pages = []\n",
    "    for i, page in enumerate(reader.pages):\n",
    "        text = (page.extract_text() or \"\").strip()\n",
    "        if len(text) >= min_chars:\n",
    "            pages.append((i + 1, text))  # (페이지번호, 텍스트)\n",
    "\n",
    "    print(f\"  유효 페이지: {len(pages)}개 (공백 제외)\")\n",
    "\n",
    "    # chunk_pages 단위로 묶기\n",
    "    chunks, meta = [], []\n",
    "    for i in range(0, len(pages), chunk_pages):\n",
    "        group = pages[i: i + chunk_pages]\n",
    "        start_pg = group[0][0]\n",
    "        end_pg   = group[-1][0]\n",
    "        combined = \"\\n\\n\".join(txt for _, txt in group)\n",
    "\n",
    "        # 임베딩용 텍스트 (앞 600자 + 페이지 정보)\n",
    "        chunk_text = f\"[현대자동차 사업보고서 p.{start_pg}~{end_pg}]\\n{combined[:600]}\"\n",
    "        chunks.append(chunk_text)\n",
    "        meta.append({\n",
    "            \"start_page\": start_pg,\n",
    "            \"end_page\":   end_pg,\n",
    "            \"text\":       combined,        # 전체 텍스트 (프롬프트용)\n",
    "            \"preview\":    combined[:300],  # 미리보기\n",
    "        })\n",
    "\n",
    "    return chunks, meta\n",
    "\n",
    "\n",
    "print(\"[사업보고서 PDF 로드 중...]\")\n",
    "report_chunks, report_meta = load_pdf_chunks(PATH_REPORT, chunk_pages=PDF_CHUNK_PAGES)\n",
    "df_report = pd.DataFrame(report_meta)\n",
    "print(f\"✅ 사업보고서 청크: {len(report_chunks)}개 생성 완료\")\n",
    "print(df_report.head(3)[['start_page', 'end_page', 'preview']])"
   ]

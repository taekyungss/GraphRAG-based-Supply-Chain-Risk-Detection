    "## 5. 검색(Retrieval) 함수 정의"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 25,
   "id": "09b0a173",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ 검색 함수 정의 완료\n",
      "\n",
      "[테스트] 쿼리: '이란 전쟁으로 인한 유가 상승'\n",
      "  검색된 협력사: 10개 (상위 유사도: 0.318)\n",
      "  검색된 수입품목: 8개 (상위 유사도: 0.346)\n",
      "  검색된 공정: 5개 (상위 유사도: 0.225)\n",
      "  검색된 보고서 청크: 5개 (상위 유사도: 0.368)\n"
     ]
    }
   ],
   "source": [
    "def retrieve(query: str, index, docs: list, metadata_df: pd.DataFrame, top_k: int = 5):\n",
    "    \"\"\"\n",
    "    쿼리 → FAISS 검색 → (score, doc_text, metadata_row) 리스트 반환\n",
    "    \"\"\"\n",
    "    q_emb = embedder.encode(\n",
    "        [query],\n",
    "        normalize_embeddings=True,\n",
    "        convert_to_numpy=True\n",
    "    )\n",
    "    scores, indices = index.search(q_emb, top_k)\n",
    "    results = []\n",
    "    for score, idx in zip(scores[0], indices[0]):\n",
    "        if idx >= 0:\n",
    "            results.append({\n",
    "                \"score\": float(score),\n",
    "                \"doc\":   docs[idx],\n",
    "                \"meta\":  metadata_df.iloc[idx].to_dict()\n",
    "            })\n",
    "    return results\n",
    "\n",
    "\n",
    "def retrieve_by_news(news_title: str, news_content: str = \"\"):\n",
    "    \"\"\"\n",
    "    뉴스 제목+내용 → 관련 협력사, 수입품목, 공정, 사업보고서 검색\n",
    "    \"\"\"\n",
    "    query = f\"{news_title} {news_content[:300]}\".strip()\n",
    "\n",
    "    partners  = retrieve(query, partner_index, partner_docs, df_partners,  TOP_K_PARTNERS)\n",
    "    imports   = retrieve(query, import_index,  import_docs,  df_imp_agg,   TOP_K_IMPORTS)\n",
    "    processes = retrieve(query, process_index, process_docs, df_process,   TOP_K_PROCESS)\n",
    "    reports   = retrieve(query, report_index,  report_chunks, df_report,   TOP_K_REPORT)\n",
    "\n",
    "    return partners, imports, processes, reports\n",
    "\n",
    "\n",
    "print(\"✅ 검색 함수 정의 완료\")\n",
    "\n",
    "# 동작 확인\n",
    "test_q = \"이란 전쟁으로 인한 유가 상승\"\n",
    "test_partners, test_imports, test_processes, test_reports = retrieve_by_news(test_q)\n",
    "print(f\"\\n[테스트] 쿼리: '{test_q}'\")\n",
    "print(f\"  검색된 협력사: {len(test_partners)}개 (상위 유사도: {test_partners[0]['score']:.3f})\")\n",
    "print(f\"  검색된 수입품목: {len(test_imports)}개 (상위 유사도: {test_imports[0]['score']:.3f})\")\n",
    "print(f\"  검색된 공정: {len(test_processes)}개 (상위 유사도: {test_processes[0]['score']:.3f})\")\n",
    "print(f\"  검색된 보고서 청크: {len(test_reports)}개 (상위 유사도: {test_reports[0]['score']:.3f})\")"
   ]
  },

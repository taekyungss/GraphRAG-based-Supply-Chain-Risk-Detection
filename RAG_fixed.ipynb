   "source": [
    "client = openai.OpenAI(api_key=OPENAI_API_KEY)\n",
    "\n",
    "SYSTEM_PROMPT = \"\"\"\n",
    "당신은 현대자동차그룹(HMG) 구매/공급망 전문 리스크 분석 AI입니다.\n",
    "주어진 뉴스와 검색된 협력사·수입 품목·공정 데이터·사업보고서를 바탕으로,\n",
    "어떤 협력사가 영향을 받는지 판단하고 그 이유를 체계적으로 정리합니다.\n",
    "\n",
    "분석 시 다음 원칙을 따릅니다:\n",
    "1. 뉴스에서 핵심 리스크 요인(지정학적 이슈, 원자재 가격, 공급 차질 등)을 식별합니다.\n",
    "2. 검색된 협력사 중 실제로 영향을 받을 가능성이 높은 업체를 선별합니다.\n",
    "3. 수입 품목 데이터와 연계하여 원자재/소재 공급 리스크를 분석합니다.\n",
    "4. 공정 데이터를 참고하여 생산 공정상 취약 지점을 식별합니다.\n",
    "5. 사업보고서 내용을 근거로 HMG 전략/재무 관점의 영향을 보완합니다.\n",
    "6. 리스크 수준을 [높음/중간/낮음]으로 명확히 표시합니다.\n",
    "7. 권고 조치(선제적 단가 협상, 대체 공급선 검토 등)를 제안합니다.\n",
    "8. 근거가 부족한 연결고리는 추측임을 명시합니다.\n",
    "\"\"\"\n",
    "\n",
    "\n",
    "def format_retrieved_context(\n",
    "    partners:  list,\n",
    "    imports:   list,\n",
    "    processes: list,\n",
    "    reports:   list,\n",
    "    partner_threshold: float = 0.3,\n",
    "    import_threshold:  float = 0.3,\n",
    "    process_threshold: float = 0.3,\n",
    "    report_threshold:  float = 0.25,\n",
    ") -> str:\n",
    "    \"\"\"검색 결과를 프롬프트용 컨텍스트 문자열로 변환\"\"\"\n",
    "\n",
    "    def section(title, items, threshold, fmt_fn):\n",
    "        filtered = [x for x in items if x[\"score\"] >= threshold]\n",
    "        out = f\"[{title}]\\n\"\n",
    "        if filtered:\n",
    "            for i, x in enumerate(filtered, 1):\n",
    "                out += f\"\\n{i}. (유사도: {x['score']:.3f})\\n{fmt_fn(x)}\\n\"\n",
    "        else:\n",
    "            out += f\"(유사도 기준 이상의 {title} 없음)\\n\"\n",
    "        return out\n",
    "\n",
    "    ctx  = section(\"검색된 협력사 후보\", partners, partner_threshold,\n",
    "                   lambda x: x['doc'])\n",
    "    ctx += \"\\n\" + section(\"검색된 수입 품목 현황\", imports, import_threshold,\n",
    "                          lambda x: x['doc'])\n",
    "    ctx += \"\\n\" + section(\"관련 공정 데이터\", processes, process_threshold,\n",
    "                          lambda x: x['doc'])\n",
    "    ctx += \"\\n\" + section(\"사업보고서 관련 내용\", reports, report_threshold,\n",
    "                          lambda x: f\"[p.{x['meta']['start_page']}~{x['meta']['end_page']}]\\n{x['meta']['preview']}\")\n",
    "    return ctx\n",
    "\n",
    "\n",
    "def analyze_risk(\n",
    "    news_title:   str,\n",
    "    news_content: str = \"\",\n",
    "    news_date:    str = \"\",\n",
    "    verbose:      bool = True\n",
    ") -> str:\n",
    "    \"\"\"\n",
    "    뉴스 입력 → 리스크 분석 보고서 반환\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    news_title   : 뉴스 제목\n",
    "    news_content : 뉴스 본문 (없으면 제목만 사용)\n",
    "    news_date    : 발행일 (참고용)\n",
    "    verbose      : 중간 과정 출력 여부\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    str : 리스크 분석 보고서 (마크다운 형식)\n",
    "    \"\"\"\n",
    "    if verbose:\n",
    "        print(f\"🔍 뉴스 분석 시작: {news_title[:60]}...\")\n",
    "\n",
    "    # ── Step 1: Retrieval ──────────────────────\n",
    "    partners, imports, processes, reports = retrieve_by_news(news_title, news_content)\n",
    "    context = format_retrieved_context(partners, imports, processes, reports)\n",
    "\n",
    "    if verbose:\n",
    "        print(f\"   협력사 {len(partners)}개 / 수입품목 {len(imports)}개 / \"\n",
    "              f\"공정 {len(processes)}개 / 보고서 {len(reports)}개 검색 완료\")\n",
    "\n",
    "    # ── Step 2: Prompt 구성 ────────────────────\n",
    "    content_preview = news_content[:800] if news_content else \"(본문 없음)\"\n",
    "\n",
    "    user_prompt = f\"\"\"다음 뉴스를 분석하여 영향 받는 HMG 협력사와 리스크 원인을 보고서 형식으로 작성해주세요.\n",
    "\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "📰 뉴스 정보\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "발행일: {news_date if news_date else '미상'}\n",
    "제목: {news_title}\n",
    "본문 (요약):\n",
    "{content_preview}\n",
    "\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "📦 RAG 검색 결과 (협력사 / 수입품목 / 공정 / 사업보고서)\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "{context}\n",
    "\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "📋 작성 요청\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "아래 형식으로 보고서를 작성해주세요:\n",
    "\n",
    "## 1. 뉴스 핵심 리스크 요인\n",
    "(뉴스에서 공급망에 영향을 줄 수 있는 핵심 요소 3~5가지)\n",
    "\n",
    "## 2. 영향 받는 협력사 분석\n",
    "(각 협력사별로: 회사명, 리스크 수준[높음/중간/낮음], 영향 받는 이유)\n",
    "단, 임베딩 유사도가 높더라도 실제 연관성이 낮다면 제외하세요.\n",
    "\n",
    "## 3. 수입 원자재/품목 리스크\n",
    "(어떤 수입품목/국가가 영향을 받는지, 단가 변동 예상)\n",
    "\n",
    "## 4. 공정 및 생산 취약 포인트\n",
    "(공정 데이터 기반, 어떤 생산 공정이 영향을 받는지)\n",
    "\n",
    "## 5. 사업보고서 관점 분석\n",
    "(HMG 전략/재무 측면에서의 영향 — 사업보고서 내용 기반)\n",
    "\n",
    "## 6. 공급망 연결 시나리오\n",
    "(뉴스 → 수입품목 영향 → 공정 차질 → 협력사 영향 → 최종 생산 차질 인과관계)\n",
    "\n",
    "## 7. 권고 조치\n",
    "(단기/중기 대응 방안, 우선순위 포함)\n",
    "\n",
    "## 8. 분석 한계 및 주의사항\n",
    "(데이터 부족이나 추측에 의한 부분 명시)\n",
    "\"\"\"\n",
    "\n",
    "    # ── Step 3: OpenAI API 호출 ────────────────\n",
    "    if verbose:\n",
    "        print(\"   OpenAI API 호출 중...\")\n",
    "\n",
    "    response = client.chat.completions.create(\n",
    "        model=\"gpt-4o\",\n",
    "        messages=[\n",
    "            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
    "            {\"role\": \"user\",   \"content\": user_prompt}\n",
    "        ],\n",
    "        max_tokens=3500,\n",
    "        temperature=0\n",
    "    )\n",
    "\n",
    "    return response.choices[0].message.content\n",
    "\n",
    "\n",
    "print(\"✅ 분석 함수 정의 완료\")"
   ]
